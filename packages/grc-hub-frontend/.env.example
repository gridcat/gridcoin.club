NEXT_PUBLIC_SITE_URL=http://localhost:3003
NEXT_PUBLIC_TRACK=false

# Opt out of Next.js telemetry (https://nextjs.org/telemetry).
# Mirrors the same flag in Dockerfile so prod builds and local dev agree.
NEXT_TELEMETRY_DISABLED=1

# Sibling API URLs used by SSR fetchers in src/lib/sources/*.ts.
# Override per-environment when sibling endpoints move (or when running
# locally against dev backends).
STAMP_API_URL=https://stamp.gridcoin.club/api
EXPLORER_API_URL=https://explorer.gridcoin.club/api
TESTNET_EXPLORER_API_URL=https://testnet-explorer.gridcoin.club/api
GRCPAY_API_URL=https://grcpay.gridcoin.club/api
